  m_Script: {fileID: 11500000, guid: 5f67c7e9798c5184d935fcf3e0f69ebc, type: 3}
  m_Name: kap2
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSO
  dialogueLines:
  - '"There it is, just up ahead. The Great Mage''s castle."'
  - '"Should I just turn back? I have all the tomes I need to make my village a better
    place."'
  - '"No... I must free all the tomes and grimoires. Even if my village gets access
    to magic, that doesn''t guarantee others will. It won''t solve the problem at
    hand."'
  - '"I have to do this. I''m coming for you, Great Mage!"'
