  m_Script: {fileID: 11500000, guid: 5f67c7e9798c5184d935fcf3e0f69ebc, type: 3}
  m_Name: kap11
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSO
  dialogueLines:
  - '"Water spells... amongst every tome I''m trying to collect, that''s the most
    important one."'
  - '"I think I get the importance of these tomes. It isn''t the spells, nope. There''s...
    real knowledge inside them too."'
  - '"I didn''t know you had to boil water to clean it! Or you''d get hurt by lightning
    more if you were wet (something I should really be doing more to these ephemerals)!"'
  - '"There''s so much to learn from them... and nobody has access to it."'
  - '"Forget the village- err, maybe I''m getting ahead of myself. Maybe I should
    take these to a scribe first, so that these tomes can be spread better across
    the realm!"'
