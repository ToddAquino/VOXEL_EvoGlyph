  m_Script: {fileID: 11500000, guid: 5f67c7e9798c5184d935fcf3e0f69ebc, type: 3}
  m_Name: kap2
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSO
  dialogueLines:
  - '"Lightning is a weird element. Everyone in the village says to not approach
    it when you''re wet, or it''s dangerous even without being wet, so don''t approach
    it at all..."'
  - '"But then we use it for everything! Er, at least, before the Great Mage took
    away all the tomes. Now nobody knows how to repair the lightning-powered machines
    or cast a lighting spell at all."'
