  m_Script: {fileID: 11500000, guid: 5f67c7e9798c5184d935fcf3e0f69ebc, type: 3}
  m_Name: kap-3-0
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSO
  dialogueLines:
  - '"So my magic works! And there''s a golem up ahead..."'
  - '"The Great Mage''s familiars still walk the land despite his exile, but they''ve
    been walking aimlessly without maintenance for so long which left them weaker
    than their prime..."'
  - '"Not that they''re NOT a danger! Even so, I can defeat it if I try my hardest!"'
